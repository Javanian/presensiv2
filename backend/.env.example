# ── Copy this file to .env and adjust values ──────────────────────────────────

# Database (use 'db' hostname when running inside Docker, 'localhost' for local dev)
DATABASE_URL=postgresql+asyncpg://presensiv2:presensiv2pass@db:5432/presensiv2

# JWT — CHANGE THIS IN PRODUCTION (min 32 random characters)
SECRET_KEY=change-this-secret-key-in-production-use-32-chars-min
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS — comma-separated JSON array of allowed origins
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Login security
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_MINUTES=30

# Rate limiting
RATE_LIMIT_LOGIN=10/minute

# Timezone
TIMEZONE=Asia/Jakarta
